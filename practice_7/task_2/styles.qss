QListView::item:selected {
    background: transparent;
}

QMenuBar {
    background: #f2f2f2;
    font-size: 16px;
    border-bottom: 1px solid #cfcfcf;
    padding: 4px;
}

QMenuBar::item {
    padding: 4px 10px;
    margin: 2px 6px;
    background: #4da3ff;
    color: #ffffff;
    border: 1px solid #2f86e5;
    border-radius: 6px;
}

QMenuBar::item:selected {
    background: #3b94f2;
    border-color: #2a7dd6;
}

QMenuBar::item:pressed {
    background: #2f86e5;
    border-color: #276fbd;
}